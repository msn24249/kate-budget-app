# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Google Sheets
GOOGLE_SHEET_ID=your_private_google_sheet_id

# Option A: keep the JSON file locally. Do not commit the real file.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Option B: paste the full service account JSON into Render as one environment variable.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Weekly report
LINE_PUSH_USER_ID=your_line_user_id
CRON_SECRET=replace_with_a_long_random_secret

# Runtime
TIMEZONE=Asia/Taipei
PORT=5000
